{
  "name": "mavu-days",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev -w @mavu/api\" \"npm run dev -w @mavu/web\"",
    "build": "npm run build -w @mavu/api && npm run build -w @mavu/web",
    "lint": "npm run lint -w @mavu/api && npm run lint -w @mavu/web",
    "typecheck": "npm run typecheck -w @mavu/api && npm run typecheck -w @mavu/web",
    "test": "npm run test -w @mavu/channels-ical",
    "db:regenerate": "npm run generate -w @mavu/db",
    "build:api": "npm run build -w @mavu/api",
    "db:migrate": "npm run migrate:dev -w @mavu/db",
    "db:seed": "npm run seed -w @mavu/db",
    "db:push": "npm run db:push -w @mavu/db",
    "compose:up": "docker compose -f docker-compose.yml up -d",
    "compose:down": "docker compose -f docker-compose.yml down",
    "postinstall": "node scripts/postinstall-prisma.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
