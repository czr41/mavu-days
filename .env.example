# Option A — Postgres from Docker Compose (`docker compose up -d` includes postgres:16 on 5432)
DATABASE_URL=postgresql://mavu:mavu@localhost:5432/mavu

# Option B — Existing PostgreSQL on the host (e.g. pgAdmin “PostgreSQL 17” on port 5433).
# Create an empty database named `mavu` first (same server as your other apps—do not reuse naapsutra).
# URL-encode special characters in the password (e.g. @ → %40).
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/mavu

REDIS_URL=redis://localhost:6379

API_HOST=0.0.0.0
API_PORT=3001
JWT_SECRET=change-me-in-dev-only-min-32-chars-xx

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=mavu-media

NEXT_PUBLIC_API_URL=http://localhost:3001

# Public marketing site — org slug from your admin (must match Organization.slug)
NEXT_PUBLIC_ORG_SLUG=mavu-days

# Canonical site URL for OG + JSON-LD (use your production domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: digits only, with country code — e.g. 9198xxxxxxx (for WhatsApp CTAs)
NEXT_PUBLIC_WHATSAPP_PHONE=

# Optional: displayed in footer mailto
NEXT_PUBLIC_BOOKING_EMAIL=

# Direct booking demo: auto-confirms like a paid webhook (local only)
MOCK_PAYMENTS=true

# Phase 2 messaging stubs (WhatsApp / Instagram)
FEATURE_PHASE2_MESSAGES=false

# Optional SMTP (otherwise logs to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=bookings@example.com
