# =============================================================================
# Copy to `.env` at repo root (never commit `.env`).
# Cloud-only DB: use Supabase URLs only; omit local Docker Postgres.
# =============================================================================

# --- Postgres (Prisma: DATABASE_URL + DIRECT_URL) ------------------------------
# Transaction pooler (runtime — port 6543 + ?pgbouncer=true):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-....pooler.supabase.com:6543/postgres?pgbouncer=true
#
# directUrl for `prisma migrate`:
# • Laptop / Oracle VM: dashboard “direct” URI (`db.<ref>.supabase.co:5432`) usually works.
# • GitHub Actions often gets Prisma P1001 to `db.*`; use Session pooler instead (Dashboard → Database → Connection string
#   → Session pooler, host `aws-*.pooler.supabase.com`, port 5432). Prefer that for repo secret DIRECT_URL when CI migrates.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-....pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-....pooler.supabase.com:5432/postgres
# URL-encode special characters in the password (@ → %40).

# Local Docker (optional — only if you still run compose Postgres):
# DATABASE_URL=postgresql://mavu:mavu@localhost:5432/mavu
# DIRECT_URL=postgresql://mavu:mavu@localhost:5432/mavu

# --- API server (@mavu/api) --------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3001
JWT_SECRET=change-me-in-dev-only-min-32-chars-xx

# Optional: BullMQ iCal worker only — omit unless you run `docker compose --profile worker up` + `npm run worker -w @mavu/api`
# REDIS_URL=redis://localhost:6379
#
# Automatic inbound calendar pulls (Airbnb/Booking → Mavu) inside the main API process. Default 900000 ms = 15 minutes.
# Set to 0 to disable here and use only the separate worker above (avoid running both or you double-fetch feeds).
# ICAL_SYNC_INTERVAL_MS=900000

# --- Object storage (optional — use R2/S3 in production; omit until uploads) ----
# S3_ENDPOINT=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# --- Next.js public (@mavu/web) -----------------------------------------------
# Browser-visible base URL for the Fastify API only (no trailing slash). Admin + booking flows call this host.
# Production: must NOT be your Vercel marketing domain—use your API deployment (e.g. https://api.mavudays.com).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Org slug from your tenant (must match Organization.slug in DB)
NEXT_PUBLIC_ORG_SLUG=mavu-days

# Canonical site URL for OG + JSON-LD and admin image previews.
# Local: http://localhost:3000 is fine. Production: MUST be your real HTTPS marketing domain — if you leave localhost here,
# CMS gallery <img> src can point at http://localhost:3000/... and thumbnails break for everyone.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API (@mavu/api): When CMS/media stores absolute URLs matching this origin, public JSON exposes path-only (e.g. /hero.jpg). Optional.
# PUBLIC_WEB_ORIGIN=https://www.example.com

NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_BOOKING_EMAIL=

# --- API behaviour ------------------------------------------------------------
MOCK_PAYMENTS=true
FEATURE_PHASE2_MESSAGES=false

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=bookings@example.com

# --- Guest review sync (admin: CMS → Reviews → Sync from Google/Airbnb) -----
# Requires Google Places API (New): Place Details with `reviews` in the field mask (may bill under Maps “Enterprise + Atmosphere” SKUs).
# GOOGLE_PLACES_API_KEY=
#
# Oracle VM production: put the same vars in `/opt/mavu-days/.env` (or whichever path matches API_DEPLOY_PATH).
# Optionally set repository secrets GOOGLE_PLACES_API_KEY / OUTSCRAPER_API_KEY — the “Deploy API (Oracle VM)” workflow
# upserts non-empty secrets into that `.env` on each deploy.

# Fallback alias if only one key is exported (same key enabled for Places API New):
# GOOGLE_MAPS_API_KEY=

# Airbnb has no documented public REST API. Optional OUTSCRAPER_API_KEY (paid, https://api.outscraper.cloud) is the stable path;
# without it review sync parses embedded JSON from the listing HTML (often yields nothing if Airbnb serves reviews only via client JS).
# OUTSCRAPER_API_KEY=

# -----------------------------------------------------------------------------
# Supabase REST / JS client — NOT used by this repo (DB access is Prisma → Postgres).
# You do not need NEXT_PUBLIC_SUPABASE_* or service_role keys for the current code.
# -----------------------------------------------------------------------------
