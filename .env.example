# =============================================================================
# Local development — copy to `.env` at repo root (never commit `.env`).
# =============================================================================

# --- Postgres (Prisma: DATABASE_URL + DIRECT_URL) ------------------------------
# Local Docker Compose (postgres service):
DATABASE_URL=postgresql://mavu:mavu@localhost:5432/mavu
DIRECT_URL=postgresql://mavu:mavu@localhost:5432/mavu

# Supabase (production / hosted — examples; paste from Supabase dashboard):
# Runtime / pooled (Transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations / direct (IPv4 add-on host or direct connection, port 5432):
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Existing PostgreSQL on host — URL-encode special chars in password (@ → %40).

# --- API server (@mavu/api) --------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3001
JWT_SECRET=change-me-in-dev-only-min-32-chars-xx

# Optional: BullMQ iCal worker only — omit unless you run `docker compose --profile worker up` + `npm run worker -w @mavu/api`
# REDIS_URL=redis://localhost:6379

# --- Object storage (optional — omit until uploads are wired) ----------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET=mavu-media

# --- Next.js public (@mavu/web) -----------------------------------------------
# Browser-visible base URL for the Fastify API (deploy API separately, e.g. Railway/Render/Fly).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Org slug from your tenant (must match Organization.slug in DB)
NEXT_PUBLIC_ORG_SLUG=mavu-days

# Canonical site URL for OG + JSON-LD (production: https://your-domain.vercel.app or custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_BOOKING_EMAIL=

# --- API behaviour ------------------------------------------------------------
MOCK_PAYMENTS=true
FEATURE_PHASE2_MESSAGES=false

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=bookings@example.com

# -----------------------------------------------------------------------------
# Supabase REST / JS client — NOT used by this repo (DB access is Prisma → Postgres).
# You do not need NEXT_PUBLIC_SUPABASE_* or service_role keys for the current code.
# -----------------------------------------------------------------------------
