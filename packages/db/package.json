{
  "name": "@mavu/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/prisma-generate-with-placeholder-env.cjs && tsc",
    "generate": "node ../../scripts/prisma-generate-with-placeholder-env.cjs",
    "migrate:dev": "node ./scripts/with-repo-env-run.mjs prisma migrate dev",
    "migrate:deploy": "node ./scripts/with-repo-env-run.mjs prisma migrate deploy",
    "migrate:deploy:ci": "prisma migrate deploy",
    "db:push": "node ./scripts/with-repo-env-run.mjs prisma db push",
    "seed": "node ./scripts/with-repo-env-run.mjs tsx prisma/seed.ts",
    "reset-password": "node ./scripts/with-repo-env-run.mjs tsx prisma/reset-password.ts"
  },
  "prisma": {
    "seed": "node ./scripts/with-repo-env-run.mjs tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "prisma": "^6.3.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  }
}